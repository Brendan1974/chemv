<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="wt_account_reporting_extended.AccountReportFilterAccount">
        <Dropdown menuClass="'account_report_filter o_filter_account'">
            <button class="btn btn-secondary">
                <i class="fa fa-bars me-1"/>Sales Person:
                <t t-set="selected_account" t-value="controller.options.account.filter(a => a.selected).map(a => a.account_name).join(', ')"/>
                <t t-if="selected_account">
                    <t t-out="' ' + selected_account"/>
                </t>
                <t t-else="">
                    All
                </t>
            </button>

            <t t-set-slot="content">
                <div role="separator" class="dropdown-divider"/>
                <span class="ml-4 text_color_bold text-center" style="padding-left:21px;font-weight:bold;">Accounts:</span>
                <div role="separator" class="dropdown-divider mt4"/>
                <t t-foreach="controller.options.account" t-as="account" t-key="account_index">
                    <DropdownItem
                        class="{ 'selected': account.selected }"
                        onSelected="() => this.selectAccount(account)"
                        closingMode="'none'"
                        t-out="account.account_name"
                    />
                </t>
            </t>
        </Dropdown>
    </t>
</templates>
