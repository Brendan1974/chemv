<odoo>
  <data>
    <record id="view_invoice_form_inherited_ap" model="ir.ui.view">
        <field name="name">view.invoice.form.inherited.ap</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='price_unit']" position="after">
                <field name="margin"/>
                <field name="margin_percent"/>
            </xpath>
            <xpath expr="//field[@name='tax_totals']" position="after">
                <label for="margin" groups="base.group_user"/>
                <div class="text-nowrap" groups="base.group_user">
                    <field name="margin" class="oe_inline"/>
                    <field name="amount_untaxed" invisible="1"/>
                    <span class="oe_inline" invisible="amount_untaxed == 0">
                        (<field name="margin_percent" nolabel="1" class="oe_inline" widget="percentage"/>)
                    </span>
                </div>
            </xpath>
        </field>
    </record>

    <record id="view_order_form_sale_order_line_no_create" model="ir.ui.view">
        <field name="name">sale.order.form.line.no.create</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']//field[@name='product_id'][@widget='sol_product_many2one']" position="attributes">
                <attribute name="options">{'no_open': True, 'no_create': True, 'no_create_edit': True}</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']//field[@name='product_template_id']" position="attributes">
                <attribute name="options">{'no_open': True, 'no_create': True, 'no_create_edit': True}</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']//field[@name='product_id'][@widget='many2one_barcode']" position="attributes">
                <attribute name="options">{'no_create': True, 'no_create_edit': True}</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_order_form_purchase_order_line_no_create" model="ir.ui.view">
        <field name="name">purchase.order.form.line.no.create</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']//field[@name='product_id'][@widget='product_label_section_and_note_field']" position="attributes">
                <attribute name="options">{'no_create': True, 'no_create_edit': True}</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']//field[@name='product_id'][@widget='many2one_barcode']" position="attributes">
                <attribute name="options">{'no_create': True, 'no_create_edit': True}</attribute>
            </xpath>
        </field>
    </record>
  </data>
</odoo>